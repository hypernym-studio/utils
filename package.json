{
  "name": "@hypernym/utils",
  "version": "3.4.8",
  "author": "Hypernym Studio",
  "description": "A collection of reusable utilities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypernym-studio/utils.git"
  },
  "homepage": "https://github.com/hypernym-studio/utils",
  "funding": "https://github.com/sponsors/ivodolenc",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "import": "./dist/fs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "hyper",
    "hypernym",
    "javascript",
    "typescript",
    "collection",
    "utilities",
    "shareable",
    "helpers",
    "shared",
    "utils",
    "types",
    "kit",
    "js",
    "ts"
  ],
  "scripts": {
    "dev:browser": "vite playgrounds/browser",
    "dev:server": "bun --watch playgrounds/server/main.ts",
    "build": "hyperbundler",
    "test": "vitest -c test/vitest.config.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@types/node": ">=20.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hypernym/bundler": "^0.32.0",
    "@hypernym/oxlint-config": "^0.1.0",
    "@hypernym/tsconfig": "^2.7.0",
    "@types/node": "^25.3.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
